{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ATEM Fleet Admin",
  "version": "0.2.0",
  "identifier": "com.allansargeant.atem-fleet-admin",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "ATEM Fleet Admin",
        "width": 460,
        "height": 500,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["launcher.toml", "node", "atem-fleet-admin-app/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": "entitlements.plist"
    }
  }
}
